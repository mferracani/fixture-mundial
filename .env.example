# Proveedor de datos deportivos (opcional).
# Si estas variables NO están seteadas, la app usa el mock local
# src/data/worldcup-2026.mock.json automáticamente.

# Base URL del proveedor de datos (ej: https://api.proveedor.com/v3)
VITE_SPORTS_API_BASE_URL=

# API Key del proveedor
VITE_SPORTS_API_KEY=
